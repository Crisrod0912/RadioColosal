<!doctype html>
<html lang="es">

<%- include('../layout/eventos/agregarEventoHead') %>

    <body class="min-vh-100 d-flex flex-column">

        <div class="container">
            <h1>Nuevo evento</h1>

            <% if (typeof error !=='undefined' ) { %>
                <div class="alert-error">
                    <%= error %>
                </div>
                <% } %>

                    <form action="/eventos/agregarEvento" method="POST">
                        <div class="form-group">
                            <label for="nombre">Nombre:</label>
                            <input type="text" id="nombre" name="nombre" required>
                        </div>

                        <div class="form-group">
                            <label for="tipo">Tipo:</label>
                            <input type="text" id="tipo" name="tipo" required>
                        </div>

                        <div class="form-group">
                            <label for="descripcion">Descripción:</label>
                            <textarea id="descripcion" name="descripcion" rows="3" required></textarea>
                        </div>

                        <div class="form-group">
                            <label for="fecha">Fecha:</label>
                            <input type="date" id="fecha" name="fecha" required>
                        </div>

                        <div class="form-group">
                            <label for="ubicacion">Ubicación:</label>
                            <input type="text" id="ubicacion" name="ubicacion" required placeholder="Dirección exacta">
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">Agendar</button>
                            <a href="/" class="btn btn-cancel">Volver al Inicio</a>
                        </div>
                    </form>
        </div>

        <%- include('../layout/eventos/agregarEventoScripts') %>

    </body>

</html>
